# ── Rewrite model ────────────────────────────────────────────────────────────
# The app uses Anthropic Claude (Opus 4.8 — the strongest rewrite, best at
# preserving the original author's voice) whenever ANTHROPIC_API_KEY is set.
# Get a key with credits at https://console.anthropic.com.
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-opus-4-8

# ── Fallback model (Google Gemini) ───────────────────────────────────────────
# Used only if ANTHROPIC_API_KEY is blank, or if you force it with
# LLM_PROVIDER=gemini. Get a free key at https://aistudio.google.com/apikey.
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-pro

# Force a provider explicitly: anthropic | gemini. Leave blank to auto-pick
# (Anthropic when its key is present, else Gemini).
# LLM_PROVIDER=anthropic

# Path to the gstack browse binary (auto-detected if unset)
# BROWSE_BIN=C:\Users\you\.claude\skills\gstack\browse\dist\browse.exe
