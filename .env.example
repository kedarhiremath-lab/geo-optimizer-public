# Google AI Studio API key. Get one at https://aistudio.google.com/apikey.
# Free tier works (with daily caps); billing removes the caps and unlocks Pro.
GEMINI_API_KEY=your-key-here

# Primary model for the rewrite. Defaults to gemini-2.5-pro (strongest), and
# automatically falls back to gemini-2.5-flash -> gemini-2.5-flash-lite if Pro
# is unavailable or rate-limited. Point this at any newer model when available.
GEMINI_MODEL=gemini-2.5-pro

# Path to the gstack browse binary (auto-detected if unset)
# BROWSE_BIN=C:\Users\you\.claude\skills\gstack\browse\dist\browse.exe
