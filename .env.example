# ── Rewrite model ────────────────────────────────────────────────────────────
# The app uses Anthropic Claude (Opus 4.8 — the strongest rewrite, best at
# preserving the original author's voice) whenever ANTHROPIC_API_KEY is set.
# Get a key with credits at https://console.anthropic.com.
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-opus-4-8

# ── Fallback model (Google Gemini) ───────────────────────────────────────────
# Used only if ANTHROPIC_API_KEY is blank, or if you force it with
# LLM_PROVIDER=gemini. Get a free key at https://aistudio.google.com/apikey.
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-pro

# Force a provider explicitly: anthropic | gemini. Leave blank to auto-pick
# (Anthropic when its key is present, else Gemini).
# LLM_PROVIDER=anthropic

# ── Real AI-generated figure images (#2) ─────────────────────────────────────
# Off by default (figures render as inline SVG). Turn on real image generation by
# choosing a provider + adding its key. ~$0.02-0.08 per image.
#   OpenAI:  IMAGE_API=openai  + OPENAI_API_KEY=sk-...
#   Google:  IMAGE_API=google  + GEMINI_IMAGE_API_KEY=...  (a billing-enabled key)
# IMAGE_API=openai
# OPENAI_API_KEY=sk-your-openai-key
# IMAGE_QUALITY=medium   # openai only: low | medium | high

# ── Durable article repository (#6) ──────────────────────────────────────────
# Without these, saved articles live in the local file cache — which is WIPED on
# every restart / idle spin-down on hosts like Render's free tier (so the
# dashboard empties out). Set both (from a free Upstash Redis database at
# https://upstash.com) and the repository persists FOREVER across restarts.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-rest-token

# Path to the gstack browse binary (auto-detected if unset)
# BROWSE_BIN=C:\Users\you\.claude\skills\gstack\browse\dist\browse.exe

# ── Wix write-back (batch --push) ────────────────────────────────────────────
# Needed only to write optimized articles back into Wix as DRAFTS (npm run batch
# -- --push). Without these, the batch runs in dry-run mode (local ./out only).
# Create an API key as the Wix account OWNER at manage.wix.com -> Settings ->
# API Keys. Give it the "Blog / Manage Blog" permission and access to the site.
# The site ID is the segment after /dashboard/ in your Wix site dashboard URL.
# The batch only UPDATES drafts (never publishes) — you publish from the Wix UI.
# WIX_API_KEY=your-wix-api-key
# WIX_SITE_ID=your-wix-site-id
